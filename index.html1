<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MogibForge — منصّة الذكاء الاصطناعي المفتوحة (نسخة مطوّرة)</title>
<meta name="description" content="MogibForge: منصة ذكاء اصطناعي مفتوحة المصدر — تفكير عميق جماعي متعدد النماذج، توليد صور، بناء أكواد، إدارة مشاريع، عضويات وصلاحيات.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@300;400;600;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --void:#0A0908;
  --panel:#151209;
  --panel-2:#1C170E;
  --panel-3:#242015;
  --line:#2E2818;
  --gold:#C9A227;
  --gold-bright:#F3D876;
  --gold-dim:#7A5B12;
  --text:#EFE8D8;
  --text-muted:#9A9078;
  --danger:#B84A3E;
  --success:#4CA35A;
  --radius:12px;
  --radius-sm:8px;
  --shadow:0 8px 24px rgba(0,0,0,.35);
  --font-display:'Amiri', serif;
  --font-body:'Cairo', sans-serif;
  --font-mono:'IBM Plex Mono', monospace;
}
*{box-sizing:border-box;}
html,body{height:100%;}
body{
  margin:0;
  background:radial-gradient(ellipse at 20% -10%, rgba(201,162,39,.10), transparent 45%),
    radial-gradient(ellipse at 100% 10%, rgba(201,162,39,.06), transparent 40%),
    var(--void);
  color:var(--text);
  font-family:var(--font-body);
  overflow:hidden;
}
::selection{background:var(--gold-dim);color:var(--gold-bright);}
::-webkit-scrollbar{width:8px;height:8px;}
::-webkit-scrollbar-thumb{background:var(--gold-dim);border-radius:4px;}
::-webkit-scrollbar-track{background:transparent;}
a{color:var(--gold);}
svg.icon{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.8;flex-shrink:0;}

.app-shell{display:flex;height:100vh;width:100vw;}
.mobile-bar{display:none;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--panel);border-bottom:1px solid var(--line);position:sticky;top:0;z-index:20;}
.mobile-bar .brand-mini{display:flex;align-items:center;gap:8px;font-family:var(--font-display);color:var(--gold-bright);font-size:16px;}
.hamburger{background:transparent;border:1px solid var(--line);border-radius:8px;padding:8px;color:var(--gold);}
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:29;}
.sidebar-overlay.show{display:block;}

.sidebar{
  width:272px; min-width:272px;
  background:linear-gradient(180deg, var(--panel) 0%, #0D0B07 100%);
  border-left:1px solid var(--line);
  display:flex; flex-direction:column; padding:22px 16px;
  overflow-y:auto;
}
.brand{display:flex;align-items:center;gap:12px;padding:0 6px 20px;border-bottom:1px solid var(--line);margin-bottom:16px;}
.brand-emblem{flex-shrink:0;filter:drop-shadow(0 0 8px rgba(201,162,39,.4));animation:spin-slow 18s linear infinite;}
@keyframes spin-slow{from{transform:rotate(0)}to{transform:rotate(360deg)}}
.brand-text{display:flex;flex-direction:column;line-height:1.3;}
.brand-name{font-family:var(--font-display);font-size:21px;font-weight:700;background:linear-gradient(90deg, var(--gold-bright), var(--gold) 60%, var(--gold-dim));-webkit-background-clip:text;background-clip:text;color:transparent;}
.brand-sub{font-size:11px;color:var(--text-muted);}

.nav{display:flex;flex-direction:column;gap:3px;flex:1;}
.nav-item{display:flex;align-items:center;gap:12px;background:transparent;border:none;color:var(--text-muted);font-family:var(--font-body);font-size:14px;padding:11px 13px;border-radius:var(--radius-sm);cursor:pointer;text-align:right;transition:background .15s, color .15s;}
.nav-item svg.icon{color:var(--gold-dim);}
.nav-item:hover{background:var(--panel-2);color:var(--text);}
.nav-item.active{background:linear-gradient(90deg, rgba(201,162,39,.16), transparent);color:var(--gold-bright);border-right:2px solid var(--gold);}
.nav-item.active svg.icon{color:var(--gold-bright);}

.sidebar-footer{display:flex;align-items:center;gap:8px;font-size:11.5px;color:var(--text-muted);padding:10px 6px 0;border-top:1px solid var(--line);margin-top:8px;}
.status-dot{width:8px;height:8px;border-radius:50%;background:var(--danger);flex-shrink:0;}
.status-dot.ok{background:var(--success);}
.auth-box{padding:8px 6px 0;font-size:12px;color:var(--text-muted);}

.main{flex:1;overflow-y:auto;padding:36px 46px;}
.view{display:none;max-width:1000px;margin:0 auto;}
.view.active{display:block;animation:fade-in .25s ease;}
@keyframes fade-in{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.view-header{margin-bottom:22px;}
.view-header h1{font-family:var(--font-display);font-size:27px;color:var(--gold-bright);margin:0 0 6px;display:flex;align-items:center;gap:10px;}
.view-desc{color:var(--text-muted);font-size:14px;margin:0;max-width:70ch;}

/* -------- التحسينات الجديدة -------- */
.reasoning-controls{display:flex;gap:22px;flex-wrap:wrap;align-items:center;margin-bottom:16px;padding:16px 18px;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);}
.reasoning-controls label{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text-muted);}
.reasoning-controls select, .reasoning-controls input[type=range]{background:var(--panel-2);color:var(--text);border:1px solid var(--line);border-radius:6px;padding:6px 8px;}
.toggle-switch{display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;color:var(--text-muted);}
.toggle-switch input{accent-color:var(--gold);width:16px;height:16px;}
.ensemble-providers{display:none;flex-wrap:wrap;gap:10px;padding:12px 18px;background:var(--panel-2);border:1px solid var(--line);border-radius:var(--radius);margin-bottom:14px;font-size:12.5px;}
.ensemble-providers.show{display:flex;}
.ensemble-providers label{display:flex;align-items:center;gap:6px;color:var(--text-muted);}

.chat-window{
  height:50vh;overflow-y:auto;
  background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);
  padding:18px;margin-bottom:14px;display:flex;flex-direction:column;gap:14px;
}
.msg{max-width:84%;padding:12px 16px;border-radius:14px;font-size:14.5px;line-height:1.75;white-space:pre-wrap;}
.msg.user{align-self:flex-end;background:linear-gradient(135deg,var(--gold-bright),var(--gold-dim));color:#1a1508;font-weight:600;}
.msg.assistant{align-self:flex-start;background:var(--panel-2);border:1px solid var(--line);}
.msg.system{align-self:center;color:var(--text-muted);font-size:12px;font-style:italic;}
.think-step{border-right:2px solid var(--gold-dim);padding-right:10px;margin-bottom:10px;opacity:.92;}
.think-step .step-label{color:var(--gold);font-weight:700;font-size:12px;display:block;margin-bottom:3px;}
.ensemble-answer{border:1px solid var(--line);border-radius:8px;padding:8px 10px;margin-bottom:8px;font-size:12.5px;background:var(--panel-3);}
.ensemble-answer .src{color:var(--gold);font-weight:700;font-size:11.5px;display:flex;justify-content:space-between;}
.ensemble-final{border-top:1px dashed var(--gold-dim);margin-top:10px;padding-top:10px;}

.chat-input-row{display:flex;gap:10px;flex-wrap:wrap;}
.chat-input-row textarea{flex:1;resize:none;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);color:var(--text);padding:12px 14px;font-family:var(--font-body);font-size:14px;min-height:60px;}
.voice-btn{background:var(--panel-2);border:1px solid var(--gold-dim);border-radius:8px;padding:10px 14px;color:var(--gold);font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.voice-btn:active{transform:scale(0.95);}

button{background:linear-gradient(180deg, var(--gold-bright), var(--gold));color:#181307;border:none;border-radius:8px;padding:10px 20px;font-family:var(--font-body);font-weight:700;font-size:13.5px;cursor:pointer;transition:filter .15s, transform .1s, box-shadow .15s;}
button:hover{filter:brightness(1.1);box-shadow:0 4px 14px rgba(201,162,39,.25);}
button:active{transform:translateY(1px);}
button:disabled{opacity:.5;cursor:not-allowed;filter:none;box-shadow:none;}
button.secondary{background:var(--panel-2);color:var(--text);border:1px solid var(--gold-dim);}
button.danger{background:var(--panel-2);color:var(--danger);border:1px solid var(--danger);}

input[type=text], input[type=password], input[type=email], input[type=number], textarea, select{font-family:var(--font-body);}

.vision-tabs, .translate-tabs, .plugins-tabs, .pay-methods, .predictions-tabs{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;}
.tab-btn{background:var(--panel);color:var(--text-muted);border:1px solid var(--line);}
.tab-btn.active{background:var(--panel-2);color:var(--gold-bright);border-color:var(--gold-dim);}
.tab-panel, .ptab-panel, .pm-panel, .prtab-panel{display:none;}
.tab-panel.active, .ptab-panel.active, .pm-panel.active, .prtab-panel.active{display:block;animation:fade-in .2s ease;}
.pred-points-bar{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:12px 16px;margin-bottom:16px;font-size:13.5px;}
.pred-note{color:var(--text-muted);font-size:11.5px;}
.pred-card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:16px;margin-bottom:14px;}
.pred-card h4{margin:0 0 6px;color:var(--gold-bright);font-size:15px;}
.pred-card .pred-meta{font-size:11.5px;color:var(--text-muted);margin-bottom:8px;}
.pred-ai-opinion{background:var(--panel-2);border-radius:8px;padding:8px 12px;font-size:12.5px;color:var(--gold);margin-bottom:10px;}
.pred-options{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;}
.pred-options button{background:var(--panel-2);color:var(--text);border:1px solid var(--line);}
.pred-options button.selected{border-color:var(--gold);color:var(--gold-bright);}
.pred-stake-row{display:flex;gap:8px;align-items:center;}
.pred-stake-row input{width:110px;background:var(--panel-2);border:1px solid var(--line);border-radius:6px;padding:8px;color:var(--text);}
.leaderboard-row{display:flex;justify-content:space-between;padding:10px 14px;background:var(--panel);border:1px solid var(--line);border-radius:8px;margin-bottom:6px;font-size:13.5px;}

.image-form{display:flex;flex-direction:column;gap:10px;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:16px;margin-bottom:18px;}
.image-form input[type=text]{background:var(--panel-2);border:1px solid var(--line);border-radius:6px;padding:10px 12px;color:var(--text);}
.image-options{display:flex;gap:10px;flex-wrap:wrap;}
.image-options select, .image-options input{background:var(--panel-2);border:1px solid var(--line);border-radius:6px;padding:8px;color:var(--text);}
.image-gallery{display:grid;grid-template-columns:repeat(auto-fill, minmax(220px,1fr));gap:14px;}
.image-gallery img{width:100%;border-radius:var(--radius);border:1px solid var(--line);display:block;}
.image-card{position:relative;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:6px;font-size:12px;color:var(--text-muted);min-height:60px;}
.image-card a.dl{position:absolute;bottom:12px;left:12px;background:rgba(0,0,0,.65);color:var(--gold-bright);padding:4px 10px;border-radius:6px;font-size:11px;text-decoration:none;}

.scene3d-controls{display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap;}
.scene3d-controls select{background:var(--panel-2);border:1px solid var(--line);border-radius:6px;padding:8px;color:var(--text);}
#scene3dContainer{height:460px;border:1px solid var(--line);border-radius:var(--radius);background:radial-gradient(circle at 50% 30%, #1a160c, #050403);overflow:hidden;}

.code-workspace{display:grid;grid-template-columns:1fr 1.4fr;gap:18px;}
.code-request-panel{display:flex;flex-direction:column;gap:10px;}
#codePrompt{height:220px;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);color:var(--text);padding:14px;resize:vertical;}
.code-options{display:flex;gap:10px;flex-wrap:wrap;}
.code-options select{background:var(--panel-2);border:1px solid var(--line);border-radius:6px;padding:8px;color:var(--text);}
.code-file-tabs{display:flex;gap:6px;margin-bottom:8px;flex-wrap:wrap;}
.code-file-tabs .file-tab{background:var(--panel-2);border:1px solid var(--line);color:var(--text-muted);padding:4px 10px;border-radius:6px;font-size:12px;cursor:pointer;}
.code-file-tabs .file-tab.active{color:var(--gold-bright);border-color:var(--gold-dim);}
.code-editor{background:#0E0C08;border:1px solid var(--line);border-radius:var(--radius);padding:16px;min-height:340px;max-height:340px;overflow:auto;font-family:var(--font-mono);font-size:12.5px;color:#D8CFA9;direction:ltr;text-align:left;white-space:pre;}
.code-editor-input{width:100%;min-height:220px;background:#0E0C08;border:1px solid var(--line);border-radius:8px;color:#D8CFA9;font-family:var(--font-mono);font-size:12.5px;padding:14px;direction:ltr;text-align:left;resize:vertical;}
.code-actions{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;}

.files-toolbar{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;}
.files-explorer{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;}
.file-item, .folder-item{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:14px;text-align:center;cursor:pointer;font-size:12.5px;color:var(--text-muted);display:flex;flex-direction:column;align-items:center;gap:8px;}
.file-item:hover, .folder-item:hover{border-color:var(--gold-dim);color:var(--text);}
.file-icon{font-size:24px;}

.translate-row{display:flex;flex-direction:column;gap:10px;}
#translateInput, #manuscriptInput{min-height:120px;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);color:var(--text);padding:14px;resize:vertical;}
.translate-controls{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.translate-controls select{background:var(--panel-2);border:1px solid var(--line);border-radius:6px;padding:8px;color:var(--text);}
.translate-output, .manuscript-output{margin-top:14px;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:16px;font-size:14px;line-height:1.8;min-height:60px;white-space:pre-wrap;}

.settings-grid, .plans-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:16px;margin-bottom:20px;}
.settings-card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:16px;}
.settings-card h3{margin:0 0 8px;font-size:15px;color:var(--gold-bright);display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.badge{background:var(--gold-dim);color:#181307;font-size:10px;padding:2px 8px;border-radius:20px;font-weight:700;}
.settings-card p{font-size:12.5px;color:var(--text-muted);margin:0 0 10px;}
.settings-card input{width:100%;background:var(--panel-2);border:1px solid var(--line);border-radius:6px;padding:8px 10px;color:var(--text);font-family:var(--font-mono);}
.save-confirm{color:var(--success);font-size:13px;}
.divider{border:none;border-top:1px solid var(--line);margin:26px 0;}
.admin-subtitle{font-family:var(--font-display);font-size:18px;color:var(--gold-bright);margin:22px 0 12px;}

.admin-table{width:100%;border-collapse:collapse;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;}
.admin-table th, .admin-table td{padding:10px 12px;text-align:right;border-bottom:1px solid var(--line);font-size:13px;}
.admin-table th{color:var(--gold);background:var(--panel-2);}
.admin-table select{background:var(--panel-2);color:var(--text);border:1px solid var(--line);border-radius:6px;padding:5px;}

.plan-card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:20px;text-align:center;cursor:pointer;transition:border-color .15s, transform .15s;}
.plan-card:hover{transform:translateY(-2px);}
.plan-card.selected{border-color:var(--gold);box-shadow:0 0 0 1px var(--gold);}
.plan-card h3{color:var(--gold-bright);font-family:var(--font-display);font-size:19px;margin:0 0 6px;}
.plan-card .price{font-size:26px;color:var(--text);margin:8px 0;}
.plan-card ul{list-style:none;padding:0;margin:10px 0 0;font-size:12.5px;color:var(--text-muted);text-align:right;}
.plan-card li{padding:3px 0;}

.payment-panel{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:20px;}
.crypto-coins{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;}
#cryptoQR{background:#fff;display:inline-block;padding:10px;border-radius:8px;}
.wallet-address{font-family:var(--font-mono);font-size:12px;color:var(--gold);word-break:break-all;margin-top:10px;}
#bankCountrySelect{background:var(--panel-2);border:1px solid var(--line);border-radius:6px;padding:8px;color:var(--text);margin-bottom:10px;}
#bankDetails{font-size:13.5px;line-height:2;color:var(--text-muted);}
#paymentNote{width:100%;min-height:70px;margin:14px 0;background:var(--panel-2);border:1px solid var(--line);border-radius:8px;color:var(--text);padding:10px;}

.plugin-templates{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;}
#pluginName, #pluginDesc{width:100%;background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:10px 12px;color:var(--text);margin-bottom:8px;}
.plugin-actions{display:flex;align-items:center;gap:12px;margin:12px 0;flex-wrap:wrap;font-size:13px;color:var(--text-muted);}
.plugin-card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:14px 16px;margin-bottom:10px;}
.plugin-card h4{margin:0 0 4px;color:var(--gold-bright);font-size:15px;}
.plugin-card .meta{font-size:11.5px;color:var(--text-muted);margin-bottom:8px;}

.api-note{background:var(--panel-2);border:1px dashed var(--gold-dim);border-radius:var(--radius);padding:14px 16px;font-size:13px;color:var(--text-muted);margin-bottom:18px;}
.api-list{display:flex;flex-direction:column;gap:10px;margin-bottom:20px;}
.api-row{display:grid;grid-template-columns:1fr 1fr auto auto;gap:10px;align-items:center;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:12px 14px;}
.api-row input{background:var(--panel-2);border:1px solid var(--line);border-radius:6px;padding:7px 9px;color:var(--text);font-family:var(--font-mono);font-size:12px;}
.api-add-form{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:16px;margin-bottom:16px;}
.api-add-form input, .api-add-form select{background:var(--panel-2);border:1px solid var(--line);border-radius:6px;padding:9px 11px;color:var(--text);}
.count-pill{font-size:11.5px;background:var(--gold-dim);color:#181307;padding:2px 10px;border-radius:20px;font-weight:700;}

@media (max-width: 860px){
  .mobile-bar{display:flex;}
  .app-shell{flex-direction:column;height:auto;min-height:100vh;}
  .sidebar{position:fixed;z-index:30;top:0;bottom:0;right:0;transform:translateX(100%);transition:transform .25s;height:100vh;box-shadow:-10px 0 30px rgba(0,0,0,.5);}
  .sidebar.open{transform:translateX(0);}
  .main{padding:18px;height:auto;overflow-y:visible;}
  body{overflow:auto;}
  .code-workspace{grid-template-columns:1fr;}
  .api-row{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<svg style="display:none">
<defs>
<symbol id="icon-brain" viewBox="0 0 24 24"><path d="M9 3a3 3 0 0 0-3 3v.5A2.5 2.5 0 0 0 4 9v2a2.5 2.5 0 0 0 1 2 2.5 2.5 0 0 0-1 2v1a3 3 0 0 0 3 3h1M15 3a3 3 0 0 1 3 3v.5A2.5 2.5 0 0 1 20 9v2a2.5 2.5 0 0 1-1 2 2.5 2.5 0 0 1 1 2v1a3 3 0 0 1-3 3h-1M9 3v18M15 3v18"/></symbol>
<symbol id="icon-image" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></symbol>
<symbol id="icon-code" viewBox="0 0 24 24"><path d="M8 4L2 12l6 8M16 4l6 8-6 8"/></symbol>
<symbol id="icon-folder" viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></symbol>
<symbol id="ic