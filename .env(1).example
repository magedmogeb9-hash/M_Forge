# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/classifyCommerce

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Seed admin user
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace_with_a_bcrypt_hash

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx

# DHL
DHL_API_KEY=replace_with_dhl_key

# Fraud detection thresholds (optional overrides)
FRAUD_MAX_QTY=100
FRAUD_MAX_TOTAL=10000

# Affiliate / marketplace API keys (used by seedApiKeys.js) - all optional,
# only platforms with a key set get seeded
API_KEY_AMAZON=
API_KEY_ALIBABA=
API_KEY_ALIEXPRESS=
API_KEY_SHEIN=
API_KEY_EBAY=
API_KEY_WALMART=
API_KEY_ETSY=
API_KEY_RAKUTEN=
API_KEY_SHOPIFY=
API_KEY_JDCOM=
