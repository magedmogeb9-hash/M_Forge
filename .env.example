# ==== عام ====
NODE_ENV=development
PORT=5000

# ==== قاعدة البيانات ====
# كل وحدة لها قاعدة بيانات منفصلة تماماً - خصوصاً وحدة البنوك (أعلى درجة عزل)
MONGO_URI_CORE=mongodb://localhost:27017/platform_core
MONGO_URI_ECOMMERCE=mongodb://localhost:27017/platform_ecommerce
MONGO_URI_SOCIAL=mongodb://localhost:27017/platform_social
MONGO_URI_ADS=mongodb://localhost:27017/platform_ads
MONGO_URI_BANKING=mongodb://localhost:27017/platform_banking

# ==== المصادقة ====
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=CHANGE_ME_ANOTHER_LONG_RANDOM_STRING

# ==== التشفير (لوحدتي السوشيال ميديا والبنوك) ====
# مفتاح 32 حرف على الأقل - في الإنتاج استخدم Secrets Manager وليس هذا الملف
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_MINIMUM_SECRET_KEY

# ==== وحدة المتجر الإلكتروني (مثال: Shopify) ====
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_STORE_DOMAIN=

# ==== وحدة السوشيال ميديا (تُملأ لاحقاً حسب كل منصة تُربط فعلياً) ====
META_APP_ID=
META_APP_SECRET=
X_API_KEY=
X_API_SECRET=

# ==== وحدة الإعلانات (Meta Marketing API - الاستدعاء مجاني) ====
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=

# ==== وحدة الحسابات البنكية الرقمية ====
# PayPal: احصل على Client ID/Secret مجاناً من developer.paypal.com (Sandbox app)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
# Payoneer/Wise/Stripe: لا تتوفر Sandbox عامة بنفس سهولة PayPal بعد - تُترك فارغة حالياً
PAYONEER_CLIENT_ID=
PAYONEER_CLIENT_SECRET=

# ==== وحدة تطوير المساعد الذكي (AI Trainer) ====
# Hugging Face Inference API - مجاني بحساب شخصي على huggingface.co/settings/tokens
# اختياري: بدونه تعمل الوحدة بالكامل (كتابة/اختبار/تفعيل الكود يدوياً) لكن بدون اقتراح كود آلي
HUGGINGFACE_API_TOKEN=

# ==== ملاحظة أمان مهمة ====
# لا تضع أي مفاتيح حقيقية هنا في بيئة الإنتاج.
# في الإنتاج استخدم Secrets Manager (AWS Secrets Manager / HashiCorp Vault)
# ولا ترفع ملف .env الفعلي إلى GitHub أبداً - هو مضاف في .gitignore
